#!/usr/bin/env bash
#
# Lists the N (default 10) most recently modified Auggie sessions and prints
# each as a TAB-separated line: <session-id>\t<kebab-case-name>
#
# Each kebab-case name is produced by a small, cheap Auggie invocation
# (Haiku 4.5) that reads the session's first few user messages and
# summarises the technical subject. Lines are streamed to stdout as each
# name comes back; progress is printed to stderr. Output feeds into
# `setup-auggie-tmux-sessions`.
#
# Env overrides:
#   AUGGIE_NAMING_MODEL            default: haiku4.5
#   AUGGIE_NAMING_EARLY_MESSAGES   default: 3   (first N user msgs fed to LLM)
#   AUGGIE_NAMING_RECENT_MESSAGES  default: 5   (last N user msgs fed to LLM)
#   AUGGIE_NAMING_MSG_CHARS        default: 400 (chars per message)

set -eo pipefail

NUM_SESSIONS="${1:-10}"
NAMING_MODEL="${AUGGIE_NAMING_MODEL:-haiku4.5}"

for cmd in auggie jq; do
  if ! command -v "$cmd" >/dev/null 2>&1; then
    echo "error: '$cmd' not found in PATH" >&2
    exit 1
  fi
done

sanitize_kebab() {
  # Lowercase; keep only a-z, 0-9 and '-'; collapse hyphen runs; trim; cap
  # the result to at most 4 hyphen-separated words (in case the model got
  # chatty).
  tr '[:upper:]' '[:lower:]' \
    | tr -c 'a-z0-9-' '-' \
    | sed -E 's/-+/-/g; s/^-+//; s/-+$//' \
    | awk -F- '{
        n = (NF < 4 ? NF : 4);
        for (i = 1; i <= n; i++) printf (i > 1 ? "-%s" : "%s"), $i;
      }'
}

generate_name() {
  local messages_blob="$1"
  local session_id="$2"

  if [[ -z "$messages_blob" ]]; then
    echo "session-${session_id:0:8}"
    return
  fi

  # Use a quoted heredoc (`<<'PROMPT'`) + `read -r -d ''` instead of
  # `$(cat <<EOF ... EOF)`. The quoted delimiter disables ALL expansion inside
  # the heredoc body, which means apostrophes, backticks, `$`, `$(...)`, etc.
  # are all literal. Avoiding `$(...)` around the heredoc also sidesteps a
  # bash tokenizer quirk where an unpaired apostrophe inside a heredoc inside
  # command substitution causes a spurious "unexpected EOF" parse error.
  # The dynamic messages blob is injected afterwards via parameter expansion.
  local prompt_template
  IFS='' read -r -d '' prompt_template <<'PROMPT' || true
You will be given the first several user messages from a past coding
conversation and must produce a single kebab-case name for a tmux session
that represents the underlying technical task.

Rules (all mandatory):
1. Reply with exactly ONE token: the name, or the literal string __skip__.
   Nothing before it, nothing after.
2. No prose, no preamble, no explanation, no markdown, no quotes, no code
   fences, no trailing period. Just the bare token followed by a newline.
3. A real name must match this regex: ^[a-z][a-z0-9-]{2,40}$
4. Use 2, 3 or 4 words joined by single hyphens.
5. Do NOT browse links, call tools, or fetch anything. Base the name only on
   the text below.

When to output __skip__ instead of a name:
- __skip__ is ONLY for sessions whose ENTIRE content is trivial: e.g. the
  only user input is "hi", "hello", "test", a single keyword, or smoke-
  testing the CLI, OR the session consists of just one or two abandoned
  stub messages that don't describe anything to build, fix, review, plan,
  or investigate.
- Do NOT skip a session just because some messages are short follow-ups,
  confirmations ("thanks", "that works", "ok"), or meta-questions about
  the session itself ("are we still on track?", "did we get off topic?").
  These are normal in long sessions. If ANY of the messages describe real
  technical work, generate a name for that work instead of skipping.
- When in doubt, generate a name. Skip is rare.

Naming guidance (when not skipping):
- Describe the *subject matter* of the task (what is being built, fixed, or
  changed), not the meta-activity ("review", "triage", "plan").
- Do NOT include ticket numbers, PR numbers, issue IDs, branch names, or
  project prefixes like "GS-14795", "PR-12345", "issue-999". The engineer
  doesn't memorise these.
- If the first message is a generic skill invocation (e.g. "Load the triage
  skill" or just a ticket number), look at later messages to infer the real
  topic.
- Prefer concrete nouns/verbs from the conversation over generic labels.

Handling long sessions that drift:
- The excerpts below may be split into "EARLY MESSAGES (framing)" and
  "RECENT MESSAGES (current focus)" sections, with a note showing how many
  messages were omitted in between. This happens for long sessions that may
  have drifted across multiple topics.
- When the early and recent messages describe substantially different work,
  PRIORITISE the recent messages - they reflect what the engineer is
  actually working on now, which is what matters for a tmux session name.
- When the early and recent messages describe the same work (just with more
  depth in the later messages), draw from both to choose the most specific
  and concrete name you can.

Good responses (single line, nothing else):
search-keywords-in-crate
index-failure-handling
auto-retry-architecture
update-elastic-index-settings

Bad responses (DO NOT do any of these):
- "Based on the task, a good name would be: foo-bar"
- "The name is `foo-bar`."
- "**foo-bar**"
- "triage-issue-15447"   (ticket number, meta verb)
- "review-gs-14795"      (ticket number, meta verb)
- "pr-review"            (too generic)

USER MESSAGES (chronological, most recent last):
"""
__MESSAGES_BLOB__
"""

Now output the single kebab-case name and nothing else.
PROMPT

  local prompt="${prompt_template//__MESSAGES_BLOB__/$messages_blob}"

  local raw
  raw=$(
    auggie \
      --print \
      --quiet \
      --output-format json \
      --model "$NAMING_MODEL" \
      --dont-save-session \
      --instruction "$prompt" \
      2>/dev/null \
    | jq -r 'select(.type == "result") | .result // ""'
  ) || raw=""

  # Detect the skip sentinel. The model is instructed to emit `__skip__` but
  # in practice may drop the underscores, uppercase it, or wrap it in quotes /
  # backticks / asterisks. Normalise by lowercasing and stripping every
  # non-alphanumeric character, then match against `skip` exactly. This
  # catches `__skip__`, `skip`, `SKIP`, `"skip"`, `**skip**`, `skip.` etc.
  # without false-positiving on legitimate names like `skip-navigation` which
  # would normalise to `skipnavigation` and fail the equality check.
  local sentinel_probe
  sentinel_probe=$(printf '%s' "$raw" | tr '[:upper:]' '[:lower:]' | tr -cd 'a-z0-9')
  if [[ "$sentinel_probe" == "skip" ]]; then
    printf '__SKIP__'
    return
  fi

  local cleaned
  cleaned=$(printf '%s' "$raw" | sanitize_kebab)

  if [[ -z "$cleaned" ]]; then
    cleaned="session-${session_id:0:8}"
  fi

  printf '%s' "$cleaned"
}

# How many user messages from each session to feed the naming LLM. We take
# the first N (framing) plus the last M (current focus) because long sessions
# can drift from their initial topic - the recent messages are a stronger
# indicator of what the session is actually about right now. Each message is
# individually truncated to keep the prompt small.
NAMING_EARLY_MESSAGES="${AUGGIE_NAMING_EARLY_MESSAGES:-3}"
NAMING_RECENT_MESSAGES="${AUGGIE_NAMING_RECENT_MESSAGES:-5}"
NAMING_MSG_CHARS="${AUGGIE_NAMING_MSG_CHARS:-400}"

echo "Fetching $NUM_SESSIONS most recent Auggie sessions..." >&2
sessions_json=$(auggie session list --all -n "$NUM_SESSIONS" --json)

count=$(jq 'length' <<<"$sessions_json")
if [[ "$count" -eq 0 ]]; then
  echo "error: no Auggie sessions found" >&2
  exit 1
fi

echo "Generating kebab-case names for $count sessions (model: $NAMING_MODEL, parallel)..." >&2

# Build a blob of a session's user messages for the naming LLM. For short
# sessions (total <= early + recent) all messages are included. For longer
# sessions we include the first $early and the last $recent messages under
# separate EARLY / RECENT headers so the model can distinguish initial
# framing from the session's current focus. Message numbers are shown as
# `i/total` so the model knows roughly where each excerpt sits in the
# conversation.
build_messages_blob() {
  local idx="$1"
  jq -r \
    --argjson i "$idx" \
    --argjson early "$NAMING_EARLY_MESSAGES" \
    --argjson recent "$NAMING_RECENT_MESSAGES" \
    --argjson maxlen "$NAMING_MSG_CHARS" \
    '.[$i].userMessages // [] as $msgs
     | ($msgs | length) as $total
     | def fmt(kind; positions): positions as $ps | [$ps, .]
         | transpose
         | map("--- \(kind) message \(.[0])/\($total) ---\n\(.[1][0:$maxlen])")
         | join("\n\n");
       if $total == 0 then
         ""
       elif $total <= ($early + $recent) then
         $msgs | fmt("user"; [range(1; $total + 1)])
       else
         ($msgs[0:$early] | fmt("early"; [range(1; $early + 1)])) as $early_blob
         | ($msgs[-$recent:] | fmt("recent"; [range($total - $recent + 1; $total + 1)])) as $recent_blob
         | "EARLY MESSAGES (framing):\n\n\($early_blob)\n\n"
           + "--- ... \($total - $early - $recent) messages omitted ... ---\n\n"
           + "RECENT MESSAGES (current focus):\n\n\($recent_blob)"
       end' \
    <<<"$sessions_json"
}

# Generate names in parallel, streaming each result to stdout as soon as it
# arrives. Individual `printf` writes of short lines are atomic on POSIX
# pipes so concurrent writers don't interleave.
for i in $(seq 0 $((count - 1))); do
  session_id=$(jq -r ".[$i].sessionId" <<<"$sessions_json")
  messages_blob=$(build_messages_blob "$i")

  (
    name=$(generate_name "$messages_blob" "$session_id")
    if [[ "$name" == "__SKIP__" ]]; then
      printf '  skip: %s (no substantive task)\n' "$session_id" >&2
    else
      printf '%s\t%s\n' "$session_id" "$name"
    fi
  ) &
done
wait
